{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:backend": "tsx backend/src/server.ts",
    "dev:frontend": "vite",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "vite build",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build": "npm run build:frontend && npm run build:backend",
    "start:backend": "tsx backend/src/server.ts",
    "start": "npm run start:backend",
    "clean": "rimraf dist backend/dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "natural": "^8.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stopword": "^3.1.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/natural": "^5.1.5",
    "@types/node": "^22.14.0",
    "@types/stopword": "^2.0.3",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "concurrently": "^8.2.0",
    "rimraf": "^5.0.0"
  }
}
